{
  "$schema": "./node_modules/@opencode-ai/agent/schemas/config.json",
  "meta": {
    "version": "2.0.0",
    "project": "2WheelAgain",
    "description": "Agent/Skill mappings and discipline profiles for 2WheelAgain development. V2 — consolidated into harness/."
  },

  "agents": {
    "default": {
      "provider": "sisyphus",
      "description": "Default orchestration agent. Handles codebase navigation and simple execution."
    },
    "momus": {
      "provider": "reviewer",
      "description": "Plan critic and quality reviewer. Loads discipline files before reviewing implementation.",
      "system_prompt": "You are Momus, the Plan Critic for 2WheelAgain. Before reviewing a plan, read the relevant CODE/*/AGENTS.md files to understand constraints. Focus on: 1) RBAC compliance, 2) Prisma schema integrity, 3) Server/Client component split, 4) Zod validation coverage.",
      "knowledge_base": [
        "./CODE/backend/AGENTS.md",
        "./CODE/database/AGENTS.md",
        "./CODE/frontend/AGENTS.md",
        "./CODE/auth/AGENTS.md",
        "./CODE/admin/AGENTS.md",
        "./CODE/design/AGENTS.md",
        "./CODE/testing/AGENTS.md"
      ],
      "tools": ["read", "glob", "grep", "bash"]
    },
    "oracle": {
      "provider": "specialist",
      "description": "High-IQ read-only consultant for complex debugging, architecture decisions, and security reviews.",
      "system_prompt": "You are the Oracle for 2WheelAgain. Provide deep, read-only analysis of the codebase. Reference CODE/*/AGENTS.md discipline files when making architectural suggestions. Focus on: 1) Database query optimization (N+1 prevention), 2) API route efficiency, 3) State machine integrity, 4) Security vulnerabilities.",
      "tools": ["lsp_diagnostics", "read", "glob", "grep", "background_output"]
    },
    "metis": {
      "provider": "planner",
      "description": "Pre-planning consultant. Analyzes ambiguous requests and identifies hidden requirements before task delegation.",
      "system_prompt": "You are Metis, the Plan Consultant for 2WheelAgain. Analyze user requests to discover implicit constraints. Check against CODE/*/AGENTS.md discipline files. Output: 1) Clarified requirements, 2) Potential failure points, 3) Recommended subagent delegation strategy.",
      "tools": ["read", "glob", "grep"]
    }
  },

  "skills": {
    "frontend-ux": {
      "description": "Expert UI/UX skills for Tailwind CSS and Radix UI component implementation.",
      "applies_to": ["./CODE/design/AGENTS.md", "./CODE/frontend/AGENTS.md"],
      "commands": ["/frontend-ui-ux"]
    },
    "git-master": {
      "description": "Atomic commits, rebase/squash, history search. STRONGLY RECOMMENDED for all code changes.",
      "applies_to": ["./AGENTS.md"],
      "commands": ["/git-master"]
    },
    "playwright": {
      "description": "Browser automation and end-to-end testing with Playwright.",
      "applies_to": ["./CODE/testing/AGENTS.md"],
      "commands": ["/playwright"]
    },
    "review-work": {
      "description": "Post-implementation review orchestrator. Loads discipline profiles before evaluating work.",
      "applies_to": ["./AGENTS.md"],
      "commands": ["/review-work"]
    }
  }
}
